{
  "name": "langchain-regresion-tests",
  "version": "1.0.0",
  "description": "Regresion tests for langchain/community/ibm",
  "type": "module",
  "scripts": {
    "jest": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest",
    "test": "npm run jest",
    "test-install": "yalc add @ibm-cloud/watsonx-ai && npm install && npm install @langchain/ibm@latest @langchain/core@latest @langchain/langgraph@latest",
    "test-regression": "npm run test-install && tsc --noEmit && npm test",
    "lint": "eslint \"**/*.test.ts\"",
    "lint:fix": "eslint \"**/*.test.ts\" --fix",
    "format": "prettier --write \"**/*.test.ts\"",
    "format:check": "prettier --check \"**/*.test.ts\""
  },
  "dependencies": {
    "@ibm-cloud/watsonx-ai": "file:.yalc/@ibm-cloud/watsonx-ai",
    "@langchain/core": "^1.1.48",
    "@langchain/ibm": "^0.1.1",
    "@langchain/langgraph": "^1.3.7",
    "axios": "^1.17.0",
    "deepagents": "^1.10.2",
    "langchain": "^1.4.2",
    "zod": "^3.25.76 || ^4"
  },
  "devDependencies": {
    "@swc/core": "^1.15.40",
    "@swc/jest": "^0.2.39",
    "@eslint/js": "^9.18.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "dotenv": "^16.4.5",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^15.14.0",
    "path": "^0.12.7",
    "prettier": "^3.8.3",
    "prettier-plugin-jsdoc": "^1.8.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
